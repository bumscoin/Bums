# ─────────────────────────────────────────────────────────────
# API Server — Environment Variables
# Copy this file to .env for local development.
# On Replit: set these in the Secrets tab (not in .env files).
# On Render/Railway/Fly.io: set these as environment variables
# in your service dashboard.
# ─────────────────────────────────────────────────────────────

# Required — Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Required — Your personal Telegram chat ID (numeric).
# The bot will only accept admin commands from this ID.
# Find yours by messaging @userinfobot on Telegram.
ADMIN_CHAT_ID=

# Optional — Default Mini App URL shown in all bot buttons.
# If not set, use /set_link inside Telegram to configure it after startup.
# Can be updated at any time without redeploying via /set_link.
MINI_APP_URL=https://your-deployed-miniapp.example.com/bums-miniapp/

# Required — Port for the Express HTTP server.
# Assigned automatically by Replit / Render / Railway.
# For local development, set to any free port e.g. 3001.
PORT=3001

# ─────────────────────────────────────────────────────────────
# Notes
# ─────────────────────────────────────────────────────────────
# After the bot starts for the first time, use /set_link in Telegram
# to save the Mini App URL permanently to data/bot-config.json.
# That file takes priority over MINI_APP_URL on subsequent restarts.
