# ─────────────────────────────────────────────────────────────
# BUMS Mini App — Environment Variables
# Copy this file to .env for local development.
# On Replit: set these in the Secrets tab (not in .env files).
# IMPORTANT: Vite bakes VITE_* variables into the built bundle
# at build time. Changing them requires a rebuild.
# ─────────────────────────────────────────────────────────────

# Required — TON wallet address that receives claim transactions.
# Must be a valid TON address in any supported format.
VITE_DESTINATION_WALLET=

# Required — Base path for the Mini App (e.g. /bums-miniapp/).
# Must match the path your web server serves the app from.
BASE_PATH=/bums-miniapp/

# Required — Port for the Vite dev server.
# Assigned automatically by Replit. For local dev, set to any free port.
PORT=5173

# ─────────────────────────────────────────────────────────────
# After changing any VITE_* variable, run:
#   pnpm --filter @workspace/bums-miniapp run build
# to rebuild the frontend bundle with the new values.
# ─────────────────────────────────────────────────────────────
